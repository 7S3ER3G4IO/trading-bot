# .env.example — NEMESIS Trading Bot
# Copier ce fichier : cp .env.example .env
# Remplacer toutes les valeurs <...> par les vraies valeurs

# ─── MetaApi (IC Markets MT5) ─────────────────────────────────────────────────
METAAPI_TOKEN=<your_metaapi_cloud_token>
METAAPI_ACCOUNT_ID=<your_metaapi_account_id>
MT5_LOGIN=<your_mt5_login>
MT5_PASSWORD=<your_mt5_password>
MT5_SERVER=<your_mt5_server>           # ex: ICMarketsEU-Demo

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@postgres:5432/trading
POSTGRES_PASSWORD=<strong_random_password>

# ─── Telegram (signaux APEX ULTIMATE) ────────────────────────────────────────
BOT_TOKEN=<telegram_bot_token>
CHAT_ID=<telegram_channel_id>            # canal public signals
ADMIN_ID=<telegram_admin_user_id>        # compte admin perso (rapports)

# ─── Discord (monitoring interne) ────────────────────────────────────────────
DISCORD_MONITORING_WEBHOOK=https://discord.com/api/webhooks/<id>/<token>

# ─── Grafana ──────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=<strong_random_password>

# ─── Webhook TradingView (signaux entrants) ───────────────────────────────────
WEBHOOK_SECRET=<random_hex_32_chars>      # optionnel

# ─── Proxy (si IP VPS bloquée par MetaApi) ────────────────────────────────────
# HTTPS_PROXY=socks5://user:pass@proxy-host:1080
# ALL_PROXY=socks5://user:pass@proxy-host:1080

# ─── Modes de fonctionnement ─────────────────────────────────────────────────
SHADOW_MODE=false            # true = paper trading (ordres fictifs, 0 real)
TIME_STOP_HOURS=12           # ferme un trade après N heures sans TP1 (défaut: 12)
PROP_FIRM_MODE=true          # true = règles Prop Firm strictes (DD 5%/10%)

# ─── Feature flags ────────────────────────────────────────────────────────────
ENABLE_BACKTESTER=false      # true = lance un backtest au démarrage
ENABLE_MONTHLY_REPORT=true   # true = rapport le 1er du mois 10h UTC

# ─── Alt Data (sentiment + events) ───────────────────────────────────────────
# OPENAI_API_KEY=sk-...       # pour NLP économique (MacroNLP)
# NEWSAPI_KEY=<key>           # pour flux news

# ─── Alerting disque ──────────────────────────────────────────────────────────
# Utilisé par disk_monitor.sh (crontab */30)
# DISCORD_MONITORING_WEBHOOK est réutilisé (voir ci-dessus)
